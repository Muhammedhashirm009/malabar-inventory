{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "splashscreen"
  ],
  "remote": {
    "urls": [
      "http://127.0.0.1:8741/**",
      "http://localhost:8741/**"
    ]
  },
  "permissions": [
    "core:default",
    "allow-backup-database",
    "allow-minimize-window",
    "allow-close-window",
    "allow-set-backup-directory",
    "allow-get-backup-directory",
    "allow-clear-backup-directory"
  ]
}
